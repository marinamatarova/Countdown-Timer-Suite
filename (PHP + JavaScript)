        <button type="submit" style="background:#9b59b6;">💾 Сохранить текущий пресет</button>
    </form>
</div>
<script>
    let remaining = 0, total = 0, interval = null, isRunning = false;
    const display = document.getElementById('timerDisplay');
    const progressFill = document.getElementById('progressFill');
    const statusSpan = document.getElementById('statusMsg');

    function formatTime(sec) {
        let h = Math.floor(sec / 3600);
        let m = Math.floor((sec % 3600) / 60);
        let s = sec % 60;
        return `${h.toString().padStart(2,'0')}:${m.toString().padStart(2,'0')}:${s.toString().padStart(2,'0')}`;
    }

    function updateUI() {
        display.innerText = formatTime(remaining);
        if (total > 0) {
            let percent = ((total - remaining) / total) * 100;
            progressFill.style.width = percent + '%';
        }
    }

    function setTime(seconds) {
        if (interval) clearInterval(interval);
        isRunning = false;
        total = seconds;
        remaining = seconds;
        updateUI();
        statusSpan.innerText = `Установлено ${formatTime(seconds)}`;
        document.getElementById('presetVal').value = seconds;
    }

    function startTimer() {
        if (remaining <= 0) { statusSpan.innerText = "Установите время > 0"; return; }
        if (isRunning) return;
        isRunning = true;
        interval = setInterval(() => {
            if (remaining > 0) {
                remaining--;
                updateUI();
                if (remaining === 0) {
                    clearInterval(interval);
                    isRunning = false;
                    statusSpan.innerText = "✅ Время вышло!";
                    // Звук через Web Audio
                    try {
                        let audioCtx = new (window.AudioContext || window.webkitAudioContext)();
                        let osc = audioCtx.createOscillator();
                        let gain = audioCtx.createGain();
                        osc.connect(gain);
                        gain.connect(audioCtx.destination);
                        osc.frequency.value = 880;
                        gain.gain.value = 0.2;
                        osc.start();
                        gain.gain.exponentialRampToValueAtTime(0.00001, audioCtx.currentTime + 1);
                        osc.stop(audioCtx.currentTime + 1);
                    } catch(e) {}
                    alert("Отсчёт завершён!");
                }
            } else {
                clearInterval(interval);
                isRunning = false;
            }
        }, 1000);
        statusSpan.innerText = "⏳ Отсчёт идёт...";
    }

    function pauseTimer() {
        if (interval) { clearInterval(interval); isRunning = false; statusSpan.innerText = "⏸ Пауза"; }
    }

    function resetTimer() {
        if (interval) clearInterval(interval);
        remaining = total;
        updateUI();
        isRunning = false;
        statusSpan.innerText = "Сброшено";
    }

    document.getElementById('setBtn').onclick = () => {
        let val = document.getElementById('timeInput').value.trim();
        let parts = val.split(':').map(Number);
        let sec = 0;
        if (parts.length === 3) sec = parts[0]*3600 + parts[1]*60 + parts[2];
        else if (parts.length === 2) sec = parts[0]*60 + parts[1];
        else if (parts.length === 1) sec = parts[0];
        if (isNaN(sec) || sec < 0) sec = 0;
        setTime(sec);
    };
    document.getElementById('startBtn').onclick = startTimer;
    document.getElementById('pauseBtn').onclick = pauseTimer;
    document.getElementById('resetBtn').onclick = resetTimer;
    document.querySelectorAll('.presets button').forEach(btn => {
        btn.onclick = () => setTime(parseInt(btn.dataset.sec));
    });
    // Инициализация
    setTime(<?= $defaultTime ?>);
</script>
