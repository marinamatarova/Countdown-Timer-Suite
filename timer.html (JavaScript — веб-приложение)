<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Таймер обратного отсчёта · Веб</title>
    <style>
        * {
            box-sizing: border-box;
            user-select: none;
        }
        body {
            background: linear-gradient(145deg, #1e2a3a, #0f1724);
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            font-family: 'Segoe UI', system-ui, monospace;
            margin: 0;
            padding: 20px;
        }
        .timer-card {
            background: rgba(255,255,255,0.1);
            backdrop-filter: blur(12px);
            border-radius: 48px;
            padding: 2rem;
            box-shadow: 0 25px 40px rgba(0,0,0,0.3);
            width: 500px;
            text-align: center;
            border: 1px solid rgba(255,255,255,0.2);
        }
        h1 {
            color: #ffd966;
            margin-top: 0;
            font-weight: 600;
        }
        .time-display {
            font-size: 5rem;
            font-family: 'Courier New', monospace;
            font-weight: bold;
            background: #00000066;
            padding: 20px;
            border-radius: 60px;
            margin: 20px 0;
            letter-spacing: 5px;
            color: #f1c40f;
        }
        .progress-container {
            background: #2c3e50;
            border-radius: 30px;
            height: 20px;
            margin: 20px 0;
            overflow: hidden;
        }
        .progress-bar {
            width: 0%;
            height: 100%;
            background: #2ecc71;
            transition: width 0.2s linear;
        }
        .input-group {
            display: flex;
            gap: 10px;
            justify-content: center;
            margin: 20px 0;
        }
        input {
            font-size: 1.2rem;
            padding: 8px 16px;
            text-align: center;
            border-radius: 40px;
            border: none;
            background: #ecf0f1;
            font-family: monospace;
        }
        button {
            background: #3498db;
            border: none;
            color: white;
            font-size: 1.1rem;
            padding: 8px 20px;
            border-radius: 40px;
            cursor: pointer;
            transition: 0.1s;
            font-weight: bold;
        }
        button:hover {
            filter: brightness(1.05);
            transform: scale(0.98);
        }
        .presets {
            display: flex;
            gap: 12px;
            justify-content: center;
            margin: 20px 0;
            flex-wrap: wrap;
        }
        .presets button {
            background: #e67e22;
        }
        .controls button {
            margin: 5px;
            width: 100px;
        }
        .status {
            margin-top: 20px;
            color: #bdc3c7;
            font-style: italic;
        }
        .dark-toggle {
            background: #2c3e50;
            margin-top: 15px;
        }
    </style>
</head>
<body>
<div class="timer-card" id="app">
    <h1>⏱️ ОБРАТНЫЙ ОТСЧЁТ</h1>
    <div class="time-display" id="timerDisplay">00:00:00</div>
    <div class="progress-container">
        <div class="progress-bar" id="progressBar"></div>
    </div>
    <div class="input-group">
        <input type="text" id="timeInput" placeholder="ЧЧ:ММ:СС" value="00:01:00">
        <button id="setBtn">Установить</button>
    </div>
    <div class="presets">
        <button data-sec="60">1 мин</button>
        <button data-sec="300">5 мин</button>
        <button data-sec="600">10 мин</button>
        <button data-sec="900">15 мин</button>
    </div>
    <div class="controls">
        <button id="startBtn">▶ Старт</button>
        <button id="pauseBtn">⏸ Пауза</button>
        <button id="resetBtn">🔄 Сброс</button>
    </div>
    <div class="status" id="statusMsg">Готов</div>
    <button id="themeBtn" class="dark-toggle">🌙 Тёмная/Светлая</button>
</div>
<script>
    let remainingSeconds = 0;
    let totalSeconds = 0;
    let timerInterval = null;
    let isRunning = false;

    const displayElem = document.getElementById('timerDisplay');
    const progressBar = document.getElementById('progressBar');
    const statusMsg = document.getElementById('statusMsg');
    const timeInput = document.getElementById('timeInput');

    function formatTime(sec) {
        let h = Math.floor(sec / 3600);
        let m = Math.floor((sec % 3600) / 60);
        let s = sec % 60;
        return `${h.toString().padStart(2,'0')}:${m.toString().padStart(2,'0')}:${s.toString().padStart(2,'0')}`;
    }

    function updateDisplay() {
        displayElem.innerText = formatTime(remainingSeconds);
        if (totalSeconds > 0) {
            let percent = ((totalSeconds - remainingSeconds) / totalSeconds) * 100;
            progressBar.style.width = percent + '%';
        }
    }

    function setTimeFromInput() {
        let val = timeInput.value.trim();
        let parts = val.split(':').map(Number);
        let seconds = 0;
        if (parts.length === 3) seconds = parts[0]*3600 + parts[1]*60 + parts[2];
        else if (parts.length === 2) seconds = parts[0]*60 + parts[1];
        else if (parts.length === 1) seconds = parts[0];
        if (isNaN(seconds) || seconds < 0) seconds = 0;
        stopTimer();
        remainingSeconds = seconds;
        totalSeconds = seconds;
        updateDisplay();
        statusMsg.innerText = `Установлено ${formatTime(seconds)}`;
        if (seconds === 0) statusMsg.innerText = "Введите корректное время";
    }

    function setPreset(seconds) {
        stopTimer();
        remainingSeconds = seconds;
        totalSeconds = seconds;
        updateDisplay();
        statusMsg.innerText = `Пресет ${Math.floor(seconds/60)} мин`;
        timeInput.value = formatTime(seconds);
    }

    function startTimer() {
        if (remainingSeconds <= 0) {
            statusMsg.innerText = "Установите время больше 0";
            return;
        }
        if (isRunning) return;
        isRunning = true;
        timerInterval = setInterval(() => {
            if (remainingSeconds > 0) {
                remainingSeconds--;
                updateDisplay();
                if (remainingSeconds === 0) {
                    finishTimer();
                }
            } else {
                finishTimer();
            }
        }, 1000);
        statusMsg.innerText = "⏳ Отсчёт идёт...";
    }

    function finishTimer() {
        clearInterval(timerInterval);
        isRunning = false;
        statusMsg.innerText = "✅ Время вышло!";
        updateDisplay();
        // Звук через Web Audio (короткий гудок)
        try {
            let audioCtx = new (window.AudioContext || window.webkitAudioContext)();
            let oscillator = audioCtx.createOscillator();
            let gain = audioCtx.createGain();
            oscillator.connect(gain);
            gain.connect(audioCtx.destination);
            oscillator.frequency.value = 880;
            gain.gain.value = 0.3;
            oscillator.start();
            gain.gain.exponentialRampToValueAtTime(0.00001, audioCtx.currentTime + 1);
            oscillator.stop(audioCtx.currentTime + 1);
        } catch(e) { console.log("звук не поддерживается"); }
        // Уведомление
        if (Notification.permission === "granted") {
            new Notification("Таймер завершён!", { body: "Отсчёт окончен" });
        } else if (Notification.permission !== "denied") {
            Notification.requestPermission().then(perm => {
                if (perm === "granted") new Notification("Таймер завершён!");
            });
        }
        alert("Время вышло!");
    }

    function pauseTimer() {
        if (isRunning) {
            clearInterval(timerInterval);
            isRunning = false;
            statusMsg.innerText = "⏸ Пауза";
        }
    }

    function resetTimer() {
        stopTimer();
        setTimeFromInput();
    }

    function stopTimer() {
        if (timerInterval) clearInterval(timerInterval);
        isRunning = false;
    }

    // Темная/светлая тема
    let dark = true;
    function toggleTheme() {
        dark = !dark;
        const card = document.querySelector('.timer-card');
        if (dark) {
            card.style.background = "rgba(255,255,255,0.1)";
            card.style.color = "white";
            document.body.style.background = "linear-gradient(145deg, #1e2a3a, #0f1724)";
        } else {
            card.style.background = "rgba(255,255,255,0.9)";
            card.style.color = "#1e2a3a";
            document.body.style.background = "#ecf0f1";
        }
    }

    document.getElementById('setBtn').addEventListener('click', setTimeFromInput);
    document.getElementById('startBtn').addEventListener('click', startTimer);
    document.getElementById('pauseBtn').addEventListener('click', pauseTimer);
    document.getElementById('resetBtn').addEventListener('click', resetTimer);
    document.querySelectorAll('.presets button').forEach(btn => {
        btn.addEventListener('click', () => setPreset(parseInt(btn.dataset.sec)));
    });
    document.getElementById('themeBtn').addEventListener('click', toggleTheme);

    // Инициализация
    setTimeFromInput();
    if (Notification.permission === "default") Notification.requestPermission();
</script>
</body>
</html>
